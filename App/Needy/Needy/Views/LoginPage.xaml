<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Needy.Views.LoginPage"
             BackgroundColor="#F5F5F5"
             Title="Log in to Needy">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30" VerticalOptions="Center">

            <!-- LOGO OR TITLE (Large and legible) -->
            <Image Source="neighbors.png" HeightRequest="150" HorizontalOptions="Center"/>

            <Label Text="Welcome to Needy" FontSize="28" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center"/>

            <Label Text="The community that helps you." FontSize="18" TextColor="#666666" HorizontalOptions="Center" Margin="0,-15,0,20"/>

            <!-- ENTRY FIELDS (Large for easy touching) -->
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="EmailEntry" Placeholder="Enter your Email" Keyboard="Email" FontSize="18" BackgroundColor="White" TextColor="Black"/>
            </Border>

            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="PasswordEntry" Placeholder="Enter your Password" IsPassword="True" FontSize="18" BackgroundColor="White" TextColor="Black"/>
            </Border>

            <!-- LOGIN BUTTON -->
            <Button x:Name="LoginButton" Text="LOGIN" Clicked="OnLoginButtonClicked" FontAttributes="Bold" FontSize="20" HeightRequest="60" CornerRadius="10" BackgroundColor="#2196F3" TextColor="White" Margin="0,20,0,0"/>

            <!-- REGISTRATION -->
            <Label Text="Don't have an account? Sign up" FontSize="16" TextColor="#2196F3" HorizontalOptions="Center" TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRegisterTapped"/>
                </Label.GestureRecognizers>
            </Label>

            <!-- Error Message (Invisible at the beginning) -->
            <Label x:Name="ErrorLabel" Text="Incorrect credentials or unapproved account." TextColor="Red" IsVisible="False" HorizontalOptions="Center" FontAttributes="Bold"/>
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>