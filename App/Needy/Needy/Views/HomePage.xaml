<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Needy.Views.HomePage"
             Title="Bacheca Needy">
    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
        <Label Text="🏠 Benvenuto nella Home!" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>

        <Label Text="Qui a Marzo appariranno le richieste." FontSize="16" HorizontalOptions="Center"/>

        <Button Text="+ CHIEDI AIUTO" Clicked="OnNuovaRichiestaClicked" BackgroundColor="#4CAF50" TextColor="White" FontAttributes="Bold" CornerRadius="8" Margin="0,30,0,0"/>

        <Button x:Name="LoginButton" Text="ESCI" Clicked="OnLogoutClicked" BackgroundColor="Red" TextColor="White" CornerRadius="8" WidthRequest="150"/>
    </VerticalStackLayout>
</ContentPage>