<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Needy.Views.RegistrazionePage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F5F5F5">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="30" VerticalOptions="Center">

            <Image Source="dotnet_bot.png" HeightRequest="130" Margin="0,0,0,10" Aspect="AspectFill"/>

            <Label Text="Crea un Account" FontSize="28" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center"/>
            <Label Text="Unisciti alla comunità di Needy" FontSize="16" TextColor="Gray" HorizontalOptions="Center" Margin="0,-5,0,15"/>
            
            <!-- NOME COMPLETO -->
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="NomeEntry" Placeholder="Nome e Cognome" FontSize="16" BackgroundColor="White" TextColor="Black"/>
            </Border>
            
            <!-- QUARTIERE -->
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="QuartiereEntry" Placeholder="Il tuo quartiere" FontSize="16" BackgroundColor="White" TextColor="Black"/>
            </Border>
            
            <!-- EMAIL -->
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" FontSize="16" BackgroundColor="White" TextColor="Black"/>
            </Border>
            
            <!-- PASSWORD -->
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" FontSize="16" BackgroundColor="White" TextColor="Black"/>
            </Border>
            
            <!-- CONFERMA PASSWORD -->
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="ConfermaPasswordEntry" Placeholder="Conferma Password" IsPassword="True" FontSize="16" BackgroundColor="White" TextColor="Black"/>
            </Border>

            <!-- DOCUMENTO D'IDENTITÀ -->
            <VerticalStackLayout Spacing="5" Margin="0,10,0,0">
                <Label Text="Documento d'identità (Obbligatorio)" FontAttributes="Bold" TextColor="#333333"/>
                <Label Text="I tuoi dati sono protetti e visibili solo all'amministratore." FontSize="12" TextColor="Gray"/>

                <Button x:Name="ScegliDocumentoButton" Text="📸 CARICA FOTO" Clicked="OnScegliDocumentoClicked" BackgroundColor="#E0E0E0" TextColor="Black" CornerRadius="8" HeightRequest="45"/>

                <Label x:Name="NomeDocumentoLabel" Text="Nessun file selezionato" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>
            </VerticalStackLayout>
            
            <!-- MESSAGGIO DI ERRORE -->
            <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False" HorizontalOptions="Center" FontAttributes="Bold"/>
            
            <!-- BOTTONE REGISTRATI -->
            <Button x:Name="RegistratiButton" Text="REGISTRATI" Clicked="OnRegistratiClicked" FontAttributes="Bold" FontSize="18" HeightRequest="55" CornerRadius="10" BackgroundColor="#4CAF50" TextColor="White" Margin="0,15,0,0"/>
            
            <!-- TORNA AL LOGIN -->
            <Label Text="Hai già un account? Accedi" FontSize="16" TextColor="#2196F3" HorizontalOptions="Center" TextDecorations="Underline" Margin="0,15,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnTornaAlLoginTapped"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>