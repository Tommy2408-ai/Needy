<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Needy.Views.NewRequestPage"
             Title="Ask for Help"
             BackgroundColor="#F5F5F5">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">
            
            <Label 
            Text="What do you need?"
                FontSize="24"
                FontAttributes="Bold"
                TextColor="#333333"/>
            
            <!-- TITLE -->
            <Label Text="Title" FontAttributes="Bold"/>
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="5">
                <Entry x:Name="TitleEntry"
                       Placeholder="Ex. Shopping at the supermarket"
                       BackgroundColor="White"
                       TextColor="Black"/>
            </Border>
            
            <!-- CATEGORY -->
            <Label Text="Category" FontAttributes="Bold"/>
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="5">
                <Picker x:Name="CategoryPicker" BackgroundColor="White" TextColor="Black">
                    <Picker.Items>
                        <x:String>Shopping</x:String>
                        <x:String>Companionship</x:String>
                        <x:String>Tech</x:String>
                        <x:String>Home</x:String>
                    </Picker.Items>
                </Picker>
            </Border>
            
            <!-- DESCRIPTION -->
            <Label Text="Detailed description" FontAttributes="Bold"/>
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="5">
                <Editor x:Name="DescriptionEditor"
                        Placeholder="Write your details here (e.g. your shopping list or the time you'll be there)..."
                        HeightRequest="120"
                        BackgroundColor="White"
                        TextColor="Black"/>
            </Border>
            
            <!-- ESTIMATED DURATION -->
            <Label Text="Estimated duration (in hrs)" FontAttributes="Bold"/>
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="5">
                <Entry x:Name="DurationEntry"
                       Keyboard="Numeric"
                       Placeholder="Ex. 1"
                       BackgroundColor="White"
                       TextColor="Black"/>
            </Border>

            <!-- ERROR/SUCCESS MESSAGE -->
            <Label x:Name="StatusLabel" IsVisible="False" FontAttributes="Bold" HorizontalOptions="Center"/>
            
            <!-- BUTTON -->
            <Button x:Name="PublishButton"
                    Text="PUBLISH REQUEST"
                    Clicked="OnPublishClicked"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="18"
                    HeightRequest="55"
                    CornerRadius="8"
                    Margin="0,20,0,0"/>
            
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>