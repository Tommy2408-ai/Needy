<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Needy.Views.RegistrationPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F5F5F5">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="30" VerticalOptions="Center">

            <Image Source="secure.png" HeightRequest="110" Margin="0,0,0,10" Aspect="AspectFit" HorizontalOptions="Center"/>

            <Label Text="Create an Account" FontSize="28" FontAttributes="Bold" TextColor="#333333" HorizontalOptions="Center"/>
            <Label Text="Join the Needy community" FontSize="16" TextColor="Gray" HorizontalOptions="Center" Margin="0,-5,0,15"/>

            <!-- FULL NAME -->
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="NameEntry" Placeholder="Name and Surname" FontSize="16" BackgroundColor="White" TextColor="Black"/>
            </Border>

            <!-- NEIGHBORHOOD -->
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="NeighborhoodEntry" Placeholder="Your neighborhood" FontSize="16" BackgroundColor="White" TextColor="Black"/>
            </Border>
            
            <!-- EMAIL -->
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" FontSize="16" BackgroundColor="White" TextColor="Black"/>
            </Border>
            
            <!-- PASSWORD -->
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" FontSize="16" BackgroundColor="White" TextColor="Black"/>
            </Border>

            <!-- CONFIRM PASSWORD -->
            <Border Stroke="#CCCCCC" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="5">
                <Entry x:Name="ConfirmPasswordEntry" Placeholder="Confirm Password" IsPassword="True" FontSize="16" BackgroundColor="White" TextColor="Black"/>
            </Border>

            <!-- IDENTIFICATION -->
            <VerticalStackLayout Spacing="5" Margin="0,10,0,0">
                <Label Text="ID Document (Required)" FontAttributes="Bold" TextColor="#333333"/>
                <Label Text="Your data is protected and visible only to the administrator." FontSize="12" TextColor="Gray"/>

                <Button x:Name="ChooseDocumentButton" Text="📸 UPLOAD PHOTO" Clicked="OnChooseDocumentClicked" BackgroundColor="#E0E0E0" TextColor="Black" CornerRadius="8" HeightRequest="45"/>

                <Label x:Name="DocumentNameLabel" Text="No files selected" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- ERROR MESSAGE -->
            <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False" HorizontalOptions="Center" FontAttributes="Bold"/>

            <!-- SIGN UP BUTTON -->
            <Button x:Name="RegisterButton" Text="SIGN UP" Clicked="OnRegisterClicked" FontAttributes="Bold" FontSize="18" HeightRequest="55" CornerRadius="10" BackgroundColor="#4CAF50" TextColor="White" Margin="0,15,0,0"/>

            <!-- RETURN TO LOGIN -->
            <Label Text="Already have an account? Login" FontSize="16" TextColor="#2196F3" HorizontalOptions="Center" TextDecorations="Underline" Margin="0,15,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackToLoginTapped"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>