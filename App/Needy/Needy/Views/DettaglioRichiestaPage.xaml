<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Needy.Views.DettaglioRichiestaPage"
             Title="Dettaglio Richiesta"
             Background="#F5F5F5">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">
            
            <!-- TITOLO E CATEGORIA -->
            <Label Text="{Binding title}" FontSize="26" FontAttributes="Bold" TextColor="Black"/>
            <Label Text="{Binding category}" FontSize="16" TextColor="#2196F3" FontAttributes="Bold"/>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10"/>
            
            <!-- DESCRIZIONE -->
            <Label Text="Descrizione:" FontAttributes="Bold" TextColor="Gray" FontSize="14"/>
            <Label Text="{Binding description}" FontSize="16" TextColor="Black"/>

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10"/>
            
            <!-- DURATA -->
            <HorizontalStackLayout Spacing="10">
                <Label Text="Durata stimata:" FontAttributes="Bold" TextColor="Gray" FontSize="14"/>
                <Label Text="{Binding estimated_duration}" FontSize="14" TextColor="Black" FontAttributes="Bold"/>
                <Label Text="ore" FontSize="14" TextColor="Black"/>
            </HorizontalStackLayout>
            
            <!-- BOTTONE PER ACCETTARE -->
            <Button x:Name="AccettaButton" Text="MI OFFRO IO" BackgroundColor="#4CAF50" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="55" Margin="0,30,0,0" Clicked="OnAccettaClicked"/>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>